:\"urn:subject:1:01c27030-e8f8-4a7c-a5b3-489fdb8fea30\",\"relevance\":\"Kjernestoff\",\"relevanceId\":\"urn:relevance:core\",\"path\":\"/subject:1:01c27030-e8f8-4a7c-a5b3-489fdb8fea30/topic:2:182849/topic:2:147875/resource:1:173799\",\"breadcrumbs\":[\"UTGÅTT - Brønnteknikk (LK06)\",\"Leting og boring\",\"Boring\"],\"contextId\":\"783d830114\",\"contextType\":\"standard\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"language\":\"nb\"}],\"language\":\"nb\",\"isPrimary\":false,\"isActive\":false,\"url\":\"/r/utgatt---bronnteknikk-lk06/test-av-formasjonsstyrke-boresimulator/783d830114\"}],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"standard\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[\"IMPORTED\"]},\"traits\":[\"H5P\"],\"score\":214.68687,\"highlights\":[{\"field\":\"embedAttributes.nn\",\"matches\":[\"<em>Test</em> av formasjonsstyrken.\",\"Brønnen blir stengd før <em>testen</em>.\",\"Simulatorøvelse: LOT (Leak off <em>test</em>)\"]},{\"field\":\"title.nb\",\"matches\":[\"<em>Test</em> av formasjonsstyrke (boresimulator)\"]},{\"field\":\"content.nb\",\"matches\":[\"I denne simulatorøvelsen skal du lære hvordan en leak off <em>test</em> (LOT) gjennomføres.\",\"Hvorfor <em>tester</em> vi formasjonsstyrken?\",\"Vi tar en ny <em>test</em> hver gang en casing er satt i brønnen.\",\"Vi gjennomfører <em>testen</em> ved å pumpe sakte med sementpumpa inn i brønnen.\",\"Da <em>tester</em> vi formasjonen til et forhåndsbestemt trykk.\"]},{\"field\":\"metaDescription.nn\",\"matches\":[\"Dette er ei simulatorøving i praktisk gjennomføring av leak off <em>test</em> (LOT).\"]},{\"field\":\"metaDescription.nb\",\"matches\":[\"Dette er en simulatorøvelse i praktisk gjennomføring av leak off <em>test</em> (LOT).\"]},{\"field\":\"content.nn\",\"matches\":[\"I denne simulatorøvinga skal du lære korleis ein leak off <em>test</em> (LOT) blir gjennomført.\",\"Kvifor <em>testar</em> vi formasjonsstyrken?\",\"Vi tek ein ny <em>test</em> kvar gong ein casing er sett i brønnen.\",\"Vi gjennomfører <em>testen</em> ved å pumpe sakte med sementpumpa inn i brønnen.\",\"Då <em>testar</em> vi formasjonen til eit førehandsbestemt trykk.\"]},{\"field\":\"introduction.nn\",\"matches\":[\"I simulatoren får du øve på praktisk gjennomføring av leak off <em>test</em> (LOT).\"]},{\"field\":\"introduction.nb\",\"matches\":[\"Vi må <em>teste</em> hvor høyt trykk vi kan tilføre brønnen under boring og brønnarbeid.\",\"I simulatoren får du øve på praktisk gjennomføring av leak off <em>test</em> (LOT).\"]},{\"field\":\"embedAttributes.nb\",\"matches\":[\"<em>Test</em> av formasjonsstyrken.\",\"Brønnen stenges før <em>testen</em>.\",\"Simulatorøvelse: LOT (Leak off <em>test</em>)\"]},{\"field\":\"title.nn\",\"matches\":[\"<em>Test</em> av formasjonsstyrke (boresimulator)\"]}],\"paths\":[\"/subject:1:98cbb757-a718-4275-b87a-2248cde4b58d/topic:8af47617-ac7b-4906-86ee-dd9d6092f560/resource:1:173799\",\"/programme:e27b83e3-5cff-49b2-aac5-1ea2cc40dc53/programme:d8f53e77-15cb-4a1b-8d37-1546aad48dc7/programme:94634e41-23d5-40c6-957b-46e1fccc50c8/subject:1:98cbb757-a718-4275-b87a-2248cde4b58d/topic:8af47617-ac7b-4906-86ee-dd9d6092f560/resource:1:173799\",\"/programme:e27b83e3-5cff-49b2-aac5-1ea2cc40dc53/programme:d8f53e77-15cb-4a1b-8d37-1546aad48dc7/programme:94634e41-23d5-40c6-957b-46e1fccc50c8/subject:1:6eb22154-3d19-4551-93f5-f137bb5abba8/topic:44027e59-6369-49ee-9805-626204a032db/topic:1:eb174f63-b071-4fce-ab70-1ee400085554/resource:1:173799\",\"/subject:1:01c27030-e8f8-4a7c-a5b3-489fdb8fea30/topic:2:182849/topic:2:147875/resource:1:173799\",\"/subject:1:6eb22154-3d19-4551-93f5-f137bb5abba8/topic:44027e59-6369-49ee-9805-626204a032db/topic:1:eb174f63-b071-4fce-ab70-1ee400085554/resource:1:173799\"],\"lastUpdated\":\"2021-06-22T10:04:50.000Z\",\"license\":\"CC-BY-SA-4.0\",\"revisions\":[{\"revisionDate\":\"2030-01-01T00:00:00.000Z\",\"note\":\"Automatisk revisjonsdato satt av systemet.\",\"status\":\"needs-rev