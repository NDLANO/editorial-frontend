l-expose-headers","value":"*"},{"name":"content-encoding","value":"gzip"},{"name":"content-type","value":"application/json"},{"name":"ratelimit-limit","value":"50"},{"name":"ratelimit-remaining","value":"23"},{"name":"ratelimit-reset","value":"1"},{"name":"server","value":"tapir/1.12.2"},{"name":"vary","value":"Origin"},{"name":"via","value":"1.1 kong/3.9.1"},{"name":"x-kong-proxy-latency","value":"4"},{"name":"x-kong-request-id","value":"2beaaa721888727f0ae8b02d50076b2b"},{"name":"x-kong-upstream-latency","value":"18"},{"name":"x-ratelimit-limit-hour","value":"108000"},{"name":"x-ratelimit-limit-minute","value":"3000"},{"name":"x-ratelimit-limit-second","value":"50"},{"name":"x-ratelimit-remaining-hour","value":"107872"},{"name":"x-ratelimit-remaining-minute","value":"2972"},{"name":"x-ratelimit-remaining-second","value":"23"}],"content":{"size":-1,"mimeType":"application/json","text":"{\"totalCount\":29514,\"page\":2,\"pageSize\":10,\"language\":\"*\",\"results\":[{\"id\":11,\"title\":{\"title\":\"\",\"htmlTitle\":\"\",\"language\":\"und\"},\"metaDescription\":{\"metaDescription\":\"\",\"language\":\"und\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/11\",\"contexts\":[],\"supportedLanguages\":[],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2018-08-23T14:04:24.000Z\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":12,\"title\":{\"title\":\"sosialliberalisme\",\"htmlTitle\":\"sosialliberalisme\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Sosialliberalisme er en politisk ideologi (tankesett) som vil gjennomføre sosiale reformer innenfor rammen av det privatkapitalistiske systemet. I teorien er individet et selvstendig vesen og samtidig sosialt avhengig. Staten bør derfor til en viss grad regulere samfunnsforholdene, men bare slik at det blir sosialt forsvarlig med individuell utfoldelse.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/12\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2020-03-19T11:08:42.000Z\",\"license\":\"CC-BY-SA-4.0\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":13,\"title\":{\"title\":\"pragmatisme\",\"htmlTitle\":\"pragmatisme\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Pragmatisme er en holdning som innebærer at en retter seg etter de forhold som er.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/13\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2018-12-07T18:15:03.000Z\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":14,\"title\":{\"title\":\"konservatisme\",\"htmlTitle\":\"konservatisme\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Konservatisme er en politisk ideologi (tankesett) som ønsker å bevare det bestående og overleverte og holde fast ved den bestående samfunnsordning.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/14\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2018-12-07T18:15:04.000Z\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":15,\"title\":{\"title\":\"liberalisme\",\"htmlTitle\":\"liberalisme\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Liberalisme er en politisk ideologi som legger stor vekt på enkeltmennesket rett til å utfolde seg fritt, uten statlig innblanding. Liberalistene er opptatt av ytringsfrihet, økonomisk frihet og at alle borgere skal behandles likt.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/15\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2022-01-21T13:37:04.000Z\",\"license\":\"CC-BY-SA-4.0\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":16,\"title\":{\"title\":\"sosialisme\",\"htmlTitle\":\"sosialisme\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Sosialisme er en politisk ideologi (tankesett) som avviser privat eiendomsrett og hevder at produksjonsmidlene skal eies av samfunnet. Den tar avstand fra en kapitalistisk maktkonsentrasjon hos et fåtall, og har i stedet som mål en statlig planøkonomi som tilgodeser alle samfunnsmedlemmenes behov.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/16\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2018-12-07T18:15:05.000Z\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":17,\"title\":{\"title\":\"ideologi\",\"htmlTitle\":\"ideologi\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Ideologi er et tankesystem som gir uttrykk for et bestemt helhetlig syn på samfunnet. Ideologiene søker å gi svar på spørsmål om hvorfor samfunnet er blitt som det er, hvordan det bør være, hvilke generelle mål politikken bør ha, osv.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/17\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2018-12-07T18:15:06.000Z\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":18,\"title\":{\"title\":\"representativt demokrati\",\"htmlTitle\":\"representativt demokrati\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Representativt demokrati er en demokratisk styreform der de som skal ta politiske beslutninger, er valgt av folket. Representativt demokrati kalles ofte også for indirekte demokrati.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/18\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2018-08-21T15:56:23.000Z\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":19,\"title\":{\"title\":\"utjevningsmandat\",\"htmlTitle\":\"utjevningsmandat\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Utjevningsmandat er plasser i Stortinget som tildeles de partiene som i oppgjøret etter valget får få mandater i forhold til stemmetall. Det er 19 utjevningsmandater, ett for hvert fylke.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/19\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"IN_PROGRESS\",\"other\":[\"PUBLISHED\"]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2020-07-10T09:20:16.000Z\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"},{\"id\":20,\"title\":{\"title\":\"mandat\",\"htmlTitle\":\"mandat\",\"language\":\"nb\"},\"metaDescription\":{\"metaDescription\":\"Når en person, en organisasjon eller et utvalg får et mandat, betyr det at de får et bestemt oppdrag og fullmakt til å utføre det. De kan for eksempel få i oppdrag å utrede noe (finne ut av noe) eller styre et område. Et mandat kan også være et verv.\",\"language\":\"nb\"},\"url\":\"https://api.test.ndla.no/concept-api/v1/drafts/20\",\"contexts\":[],\"supportedLanguages\":[\"nb\",\"nn\"],\"learningResourceType\":\"concept\",\"status\":{\"current\":\"PUBLISHED\",\"other\":[]},\"traits\":[],\"score\":0.0,\"highlights\":[{\"field\":\"learningResourceType\",\"matches\":[\"<em>concept</em>\"]}],\"paths\":[],\"lastUpdated\":\"2018-08-21T15:56:04.000Z\",\"revisions\":[],\"favorited\":0,\"resultType\":\"concept\",\"typename\":\"MultiSearchSummaryDTO\"}],\"suggestions\":[],\"aggregations\":[]}"},"headersSize":-1,"bodySize":-1,"redirectURL":""},"cache":{},"timings":{"send":-1,"wait":-1,"receive":222.597}},{"startedDateTime":"2025-12-05T12:19:26.445Z","time":46.289,"request":{"method":"GET","url":"http://localhost:3000/get_note_users?userIds=f-jBTU8O8kYbUW20lMeIuTSv,d-FPKmIPUE-r4-0PvCi8JyC7","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"accept","value":"*/*"},{"name":"accept-language","value":"en-US"},{"name":"authorization","value":""},{"name